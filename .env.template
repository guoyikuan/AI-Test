# ============================================
# LLM配置 - 选择您使用的AI服务
# ============================================

# LLM提供商 (openai, anthropic, tongyi, zhipu, custom)
LLM_PROVIDER=openai

# ============================================
# OpenAI配置
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=  # 可选：自定义OpenAI兼容API地址（如国内代理）

# ============================================
# Anthropic (Claude)配置
# ============================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# 通义千问 (Tongyi/Qwen)配置
# ============================================
TONGYI_API_KEY=your_tongyi_api_key_here
# 或使用
DASHSCOPE_API_KEY=your_dashscope_api_key_here
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# 智谱AI (Zhipu/GLM)配置
# ============================================
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ============================================
# 自定义AI服务配置
# ============================================
CUSTOM_LLM_API_KEY=your_custom_api_key_here
LLM_BASE_URL=https://your-custom-ai-service.com/v1

# ============================================
# 通用LLM配置
# ============================================
LLM_MODEL=gpt-4-turbo-preview  # 模型名称
LLM_TEMPERATURE=0.7  # 温度参数 (0.0-1.0)

# ============================================
# Power BI配置（可选）
# ============================================
POWER_BI_CLIENT_ID=your_power_bi_client_id
POWER_BI_CLIENT_SECRET=your_power_bi_client_secret
POWER_BI_TENANT_ID=your_tenant_id
POWER_BI_WORKSPACE_ID=your_workspace_id
POWER_BI_DATASET_ID=your_dataset_id

# ============================================
# 测试配置
# ============================================
BASE_URL=https://your-test-environment.com
BROWSER=chromium
HEADLESS=true
TIMEOUT=30000
RETRY_COUNT=3

# ============================================
# 报告配置
# ============================================
REPORT_DIR=reports
SCREENSHOT_DIR=screenshots
VIDEO_DIR=videos

# ============================================
# CI/CD配置
# ============================================
CI_MODE=false
PARALLEL_WORKERS=4
