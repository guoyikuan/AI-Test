# 快速配置示例 - 根据您使用的AI服务取消注释对应配置

# ============================================
# 选项1: OpenAI (GPT系列)
# ============================================
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4-turbo-preview

# ============================================
# 选项2: Anthropic (Claude系列)
# ============================================
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-3-opus-20240229

# ============================================
# 选项3: 通义千问 (Tongyi/Qwen)
# ============================================
# LLM_PROVIDER=tongyi
# TONGYI_API_KEY=your_tongyi_api_key_here
# LLM_MODEL=qwen-turbo

# ============================================
# 选项4: 智谱AI (Zhipu/GLM)
# ============================================
# LLM_PROVIDER=zhipu
# ZHIPU_API_KEY=your_zhipu_api_key_here
# LLM_MODEL=glm-4

# ============================================
# 选项5: 自定义服务
# ============================================
# LLM_PROVIDER=custom
# CUSTOM_LLM_API_KEY=your_custom_api_key_here
# LLM_BASE_URL=https://your-custom-ai-service.com/v1
# LLM_MODEL=gpt-3.5-turbo

# ============================================
# 通用配置
# ============================================
LLM_TEMPERATURE=0.7

# 测试配置
BASE_URL=https://your-test-environment.com
BROWSER=chromium
HEADLESS=true
TIMEOUT=30000
RETRY_COUNT=3

# 报告配置
REPORT_DIR=reports
SCREENSHOT_DIR=screenshots
VIDEO_DIR=videos
